# Temporary files
*.tmp
*.temp
temp/
tmp/

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# Backup files
*.bak
*.backup

# Keep directory structure but ignore content in working directories
# Allow .gitkeep files to preserve empty directories
topics/*
!topics/.gitkeep
!topics/example-topic-idea.md

research/*
!research/.gitkeep

output/*
!output/.gitkeep

drafts/*
!drafts/.gitkeep

published/*
!published/.gitkeep

rewrites/*
!rewrites/.gitkeep

review-required/*
!review-required/.gitkeep

landing-pages/*
!landing-pages/.gitkeep

repurposed/*
!repurposed/.gitkeep

audits/*
!audits/.gitkeep

# Local config (copy from config/competitors.example.json)
config/competitors.json

# Don't ignore context files - these should be committed after customization
# !context/

# Node modules if using any tools
node_modules/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/

# Testing
.coverage
htmlcov/
.pytest_cache/

# Secrets and sensitive data
secrets/
credentials/*
!credentials/.gitkeep
client_secret_*.json
*.key
*.pem
*.p12

# Personal notes that shouldn't be in repo
NOTES.md
personal-*.md

# Grav publish preview output (grav-publish skill, --dry-run)
.grav-preview/

# Data source credentials and cache
data_sources/config/.env
data_sources/config/*_credentials.json
data_sources/config/*_config.json
data_sources/cache/*
!data_sources/cache/.gitkeep

# Python virtual environment
venv/
.venv/

# Local agent/tool state
.cache/
.codex/
.playwright-mcp/
.agents/*
!.agents/rules/
!.agents/rules/customer-proof.md
.mcp.json
.claude/settings.local.json
mcp-gsc/venv/
