# SEO Machine Environment Variables
# Copy this file to .env for repo-root scripts, or to data_sources/config/.env for legacy data-source scripts.
# Never commit .env files or real credential JSON files.

# ============================================
# MCP Google Analytics 4 Configuration
# ============================================
# ADC authorized-user JSON used by the analytics-mcp server.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/adc.json

# Optional project IDs used by some Google SDK clients.
GOOGLE_PROJECT_ID=your_google_project_id_here
GOOGLE_CLOUD_PROJECT=your_google_project_id_here

# ============================================
# MCP Google Search Console Configuration
# ============================================
# OAuth desktop-app client secret used by the gsc MCP server.
GSC_OAUTH_CLIENT_SECRETS_FILE=./credentials/gsc_client_secrets.json
GSC_DATA_STATE=all

# ============================================
# Local Python GA4 Configuration
# ============================================
# Numeric GA4 Property ID used by data_sources/modules/google_analytics.py.
GA4_PROPERTY_ID=your_property_id_here

# Service-account JSON used by local Python modules, not by analytics-mcp.
# Do not point this at credentials/adc.json unless the file is a service-account key.
GA4_CREDENTIALS_PATH=./credentials/ga4-credentials.json

# ============================================
# Local Python Search Console Configuration
# ============================================
# Exact GSC property URL used by data_sources/modules/google_search_console.py.
GSC_SITE_URL=https://yoursite.com/

# Service-account JSON used by local Python modules, not by the gsc MCP OAuth flow.
# Do not point this at credentials/gsc_client_secrets.json.
GSC_CREDENTIALS_PATH=./credentials/gsc-credentials.json

# ============================================
# DataForSEO API Configuration
# ============================================
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_api_password_here

# ============================================
# Optional: Blog Path Filter
# ============================================
BLOG_PATH=/blog/

# ============================================
# Optional: Company Information
# ============================================
COMPANY_NAME=Your Company Name
COMPANY_DOMAIN=yoursite.com
TARGET_INDUSTRY=your-industry
